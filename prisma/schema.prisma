datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
model budget {
  id          Int      @id @default(autoincrement())
  officeId    Int
  ps          Float
  mooe        Float
  co          Float
  total       Float
  dateCreated DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
  office      office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model disbursement {
  id              Int      @id @default(autoincrement())
  dvNo            String
  payee           String
  officeId        Int
  expenseType     String
  expenseCategory String
  amount          Float
  dateCreated     DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())
  office          office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
}
model expense {
  id          Int      @id @default(autoincrement())
  type        String
  category    String
  dateCreated DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
}

model office {
  id           Int            @id @default(autoincrement())
  name         String         @unique(map: "Office_name_key")
  dateCreated  DateTime       @default(now())
  budget       budget[]
  disbursement disbursement[]
}

model log {
  id          Int      @id @default(autoincrement())
  message     String
  type        String   // e.g. Budget, Disbursement, Expense, Office
  action      String   // e.g. create, update, delete
  performedBy String?  // username or identifier of user who performed the action
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
}

model useradmin {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
}
